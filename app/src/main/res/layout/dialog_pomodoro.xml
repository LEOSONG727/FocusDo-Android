<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_pomodoro_dark"
    android:padding="24dp">

    <!-- Close button -->
    <ImageButton
        android:id="@+id/btnClose"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_close"
        android:contentDescription="닫기"
        app:tint="@color/pomodoro_label"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Buddy character -->
    <com.focusdo.app.ui.BuddyView
        android:id="@+id/buddyView"
        android:layout_width="0dp"
        android:layout_height="130dp"
        app:layout_constraintTop_toBottomOf="@id/btnClose"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Tomato count -->
    <TextView
        android:id="@+id/tvTomatoes"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="18sp"
        android:textColor="@color/pomodoro_text"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/buddyView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Session count label -->
    <TextView
        android:id="@+id/tvSessionCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="@color/pomodoro_ring_arc"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/tvTomatoes"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Task title -->
    <TextView
        android:id="@+id/tvTaskTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/pomodoro_text"
        android:gravity="center"
        android:maxLines="2"
        android:ellipsize="end"
        android:layout_marginTop="6dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvSessionCount"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Timer ring -->
    <FrameLayout
        android:id="@+id/timerContainer"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/tvTaskTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.focusdo.app.ui.TimerRingView
            android:id="@+id/timerRing"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <TextView
            android:id="@+id/tvTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="25:00"
            android:textSize="50sp"
            android:textStyle="bold"
            android:textColor="@color/pomodoro_text"
            android:fontFamily="monospace"
            android:letterSpacing="-0.04" />
    </FrameLayout>

    <!-- Action buttons -->
    <LinearLayout
        android:id="@+id/actionButtons"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/timerContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPause"
            android:layout_width="240dp"
            android:layout_height="52dp"
            android:text="일시 정지"
            android:textStyle="bold"
            android:textColor="@color/pomodoro_text"
            style="@style/Widget.Material3.Button.OutlinedButton"
            app:strokeColor="@color/pomodoro_ring_bg"
            app:cornerRadius="@dimen/radius_md" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStop"
            android:layout_width="240dp"
            android:layout_height="52dp"
            android:layout_marginTop="10dp"
            android:text="집중 종료하기"
            android:textStyle="bold"
            app:backgroundTint="@color/btn_stop_bg"
            android:textColor="@color/system_red_dark"
            app:cornerRadius="@dimen/radius_md" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
