<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Dark mode: warm purple tones, not cold navy/charcoal -->
    <style name="Theme.FocusDo" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/dark_primary</item>
        <item name="colorOnPrimary">@color/dark_background</item>
        <item name="colorPrimaryContainer">#2A1860</item>
        <item name="colorOnPrimaryContainer">@color/dark_primary</item>
        <item name="colorSecondary">#F4B8D8</item>
        <item name="colorOnSecondary">@color/dark_background</item>
        <item name="colorSecondaryContainer">#3D1030</item>
        <item name="colorOnSecondaryContainer">#F4B8D8</item>
        <item name="colorBackground">@color/dark_background</item>
        <item name="colorSurface">@color/dark_surface</item>
        <item name="colorSurfaceVariant">@color/dark_surface_variant</item>
        <item name="colorOnSurface">@color/dark_on_surface</item>
        <item name="colorOnSurfaceVariant">@color/dark_on_surface_variant</item>
        <item name="colorError">@color/system_red_dark</item>
        <item name="android:windowBackground">@color/dark_background</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="shapeAppearanceMediumComponent">@style/Shape.FocusDo.Medium</item>
        <item name="shapeAppearanceLargeComponent">@style/Shape.FocusDo.Large</item>
    </style>

</resources>
